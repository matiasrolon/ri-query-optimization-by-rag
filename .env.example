# Método de indexación: "pyterrier" o "pisa"
INDEXING_METHOD=pyterrier
# Directorio base de datos (collection.tsv, queries/, qrels.dev.tsv)
DATA_DIR=./data
# Fracción de la colección a indexar (0.0 - 1.0)
SAMPLE_FRACTION=1.0
# Directorio donde se guardan los índices generados
INDEX_DIR=./data/index
# Forzar re-indexación aunque ya exista un índice en disco (true/false)
FORCE_REINDEX=false
