# Método de indexación: "pyterrier" o "pisa"
INDEXING_METHOD=pyterrier
# Directorio base de datos (collection.tsv, queries/, qrels.dev.tsv)
DATA_DIR=./data
# Fracción de la colección a indexar (0.0 - 1.0)
SAMPLE_FRACTION=1.0
# Directorio de salida para archivos generados (índices, resultados, etc.)
OUTPUT_DIR=./output
# Directorio donde se guardan los índices generados
INDEX_DIR=./output/index
# Forzar re-indexación aunque ya exista un índice en disco (true/false)
FORCE_REINDEX=false

# Parámetros de feedback para query expansion (PRF y RAG)
FEEDBACK_DOCS=10
FEEDBACK_TERMS=10
FEEDBACK_LAMBDA=0.6

# Configuración del LLM (usada por la expansión RAG)
# Modelo local ejecutado con Ollama (no requiere API key)
LLM_MODEL=qwen2.5:7b
LLM_BASE_URL=http://localhost:11434/v1
# API key (dejar vacío para Ollama local; configurar si se usa OpenAI/DeepSeek)
OPENAI_API_KEY=
